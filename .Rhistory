## convert to PDF
pngfile <- pdftools::pdf_convert('/Users/eugene/Desktop/Class/2026 Spring/Computational Social Science/CSS LABS/court_doc.pdf', dpi = 600)
## Perform OCR
text <- tesseract::ocr(pngfile)
## print out page 4
cat(text[4])
## First put it into a data.frame
df <- tibble(doc = 1, text = text[1])
## split into one word (token) per row
tokens <- df %>%
tidytext::unnest_tokens(word, text)
## create count of most common words over 5 characters
words <- tokens %>%
count(word, sort = TRUE) %>%
filter(nchar(word) > 5)
