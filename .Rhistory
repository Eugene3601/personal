library(haven)
df <- read_dta("/Users/eugene/Desktop/Class/2026 Spring/Longitudinal Analysis/rcode_assignments/teenalcuse.dta")
df$age14 <- df$age - 14
library(lme4)
modelB <- lmer(
alcuse ~ age14 + (1 + age14 | id),
data = df
)
summary(modelB)
#Centering PEER
df$cpeer <- df$peer - mean(df$peer, na.rm = TRUE)
df$coa <- factor(df$coa)
# Fit Model F
modelF <- lmer(
alcuse ~ age14 + coa + cpeer + age14:cpeer +
(1 + age14 || id),
data = df
)
summary(modelF)
df
#Dummy Variables
df$coa0   <- ifelse(df$coa == 1, 1, 0)
df$coa1   <- ifelse(df$coa == 0, 1, 0)
df$age140 <- df$age14 * df$coa0
df$age141 <- df$age14 * df$coa1
# Model 1
m1 <- lmer(
alcuse ~ 0 + coa0 + coa1 + age140 + age141 +
(1 + age14 || id),
data = df,
REML = FALSE
)
# Model 2
m2 <- lmer(
alcuse ~ 0 + coa0 + coa1 + age140 + age141 +
(0 + coa0  || id) +
(0 + coa1  || id) +
(0 + age14 || id),
data = df,
REML = FALSE
)
# Model 3
m3 <- lmer(
alcuse ~ 0 + coa0 + coa1 + age140 + age141 +
(0 + coa0  || id) +
(0 + coa1  || id) +
(0 + age140 || id) +
(0 + age141 || id),
data = df,
REML = FALSE
)
anova(m1, m2)
anova(m2, m3)
anova(m1, m2)
anova(m1, m2)
anova(m2, m3)
m4 <- lmer(
alcuse ~ 0 + coa0 + coa1 + age14 +
(0 + coa0  || id) +
(0 + coa1  || id) +
(0 + age14 || id),
data = df,
REML = FALSE
)
anova(m4,m2)
